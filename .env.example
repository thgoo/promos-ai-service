# ════════════════════════════════════════════════════════════════════════════
# ai-service — centralized AI capabilities for bargah.com.br
#
# Three HTTP endpoints: /api/ai/extract (deal text → structured fields),
# /api/ai/embed (text → vectors), /api/ai/judge (product matching).
# Required keys are marked [REQUIRED].
# ════════════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | production | test
PORT=3003
LOG_LEVEL=debug                       # debug | info | warn | error

# ─── LLM provider ───────────────────────────────────────────────────────────
# Backs the /extract and /judge endpoints. Choose one and provide the key.
LLM_PROVIDER=abacus                   # abacus | openai

# Abacus (RouteLLM proxy) — [REQUIRED if LLM_PROVIDER=abacus]
ABACUS_API_KEY=
ABACUS_MODEL=claude-3-7-sonnet-20250219
ABACUS_BASE_URL=https://routellm.abacus.ai/v1/chat/completions
ABACUS_TIMEOUT_MS=30000

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# [REQUIRED] for /embed (only OpenAI is supported for embeddings).
# Optional for /extract and /judge — only used when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-nano
OPENAI_LLM_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_LLM_TIMEOUT_MS=30000
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
OPENAI_EMBEDDING_TIMEOUT_MS=30000
